# Telegram bot
TELEGRAM_BOT_TOKEN=

# OPTIONAL but recommended. When set, this Telegram user ID is the authoritative
# bot owner on every start; it overrides any owner_id already in data/telegram_access.json
# and disables the first-claim fallback. Treat 0 or empty as unset.
TELEGRAM_OWNER_ID=

# Qdrant Cloud
QDRANT_URL=https://b21e5b04-433a-41b9-b23d-0416e99a40d9.australia-southeast1-0.gcp.cloud.qdrant.io
QDRANT_API_KEY=
QDRANT_COLLECTION=system_rag

# Embeddings
FASTEMBED_MODEL=intfloat/multilingual-e5-small
EMBEDDING_DIM=384

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=80
TOP_K=6
MIN_RELEVANCE_SCORE=0.78

# Inference (OpenAI-compatible chat completion endpoint, single path)
INFERENCE_BASE_URL=
INFERENCE_API_KEY=
INFERENCE_MODEL=
INFERENCE_TEMPERATURE=0.2

# OPTIONAL one-time seed for the persistent embed allowlist (data/telegram_access.json).
# Read ONLY on the first bot run when the access file does not exist. After that, edit the
# JSON file directly or use the /allow, /disallow, /allowlist bot commands. Empty = no seed.
TELEGRAM_SEED_ALLOWLIST=

# Persistent owner/allowlist storage location (default: data/telegram_access.json).
ACCESS_FILE=data/telegram_access.json

# Runtime
LOG_LEVEL=INFO
LOG_FILE=logs/rag-qdrant.log
UPLOAD_DIR=storage/uploads
TEXT_MESSAGE_DIR=storage/text_messages
