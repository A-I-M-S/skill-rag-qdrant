# Qdrant (Cloud or self-hosted)
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=system_rag

# Embeddings (FastEmbed)
FASTEMBED_MODEL=intfloat/multilingual-e5-small
EMBEDDING_DIM=384

# Chunking and retrieval
CHUNK_SIZE=900
CHUNK_OVERLAP=150
TOP_K=6
MIN_RELEVANCE_SCORE=0.78

# Inference (any OpenAI-compatible chat completion endpoint)
INFERENCE_BASE_URL=
INFERENCE_API_KEY=
INFERENCE_MODEL=
INFERENCE_TEMPERATURE=0.2

# Runtime
LOG_LEVEL=INFO
LOG_FILE=logs/rag-qdrant.log
