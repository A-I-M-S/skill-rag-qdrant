# Qdrant (Cloud or self-hosted)
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=system_rag

# Embeddings (FastEmbed)
FASTEMBED_MODEL=intfloat/multilingual-e5-small
EMBEDDING_DIM=384

# Chunking and retrieval
CHUNK_SIZE=900
CHUNK_OVERLAP=150
TOP_K=6
MIN_RELEVANCE_SCORE=0.78

# Inference (any OpenAI-compatible chat completion endpoint)
INFERENCE_BASE_URL=
INFERENCE_API_KEY=
INFERENCE_MODEL=
INFERENCE_TEMPERATURE=0.2

# Runtime
LOG_LEVEL=INFO
LOG_FILE=logs/rag-qdrant.log

# Photo storage (description-based RAG matching).
# Photos are content-addressed by sha256 under this directory; the
# directory is created on the first photo write.
RAG_PHOTOS_DIR=/root/rag-photos

# Caching (opt-in; both disabled by default)
# Semantic cache: keyed by question similarity (cosine)
SEMANTIC_CACHE_ENABLED=0
SEMANTIC_CACHE_PATH=logs/semantic_cache.sqlite
SEMANTIC_CACHE_TTL_SECONDS=86400
SEMANTIC_CACHE_MISS_TTL_SECONDS=3600
SEMANTIC_CACHE_MAX_ENTRIES=1000
SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.88
SEMANTIC_CACHE_CACHE_MISSES=1

# Search result cache: keyed by exact question hash + settings
SEARCH_CACHE_ENABLED=0
SEARCH_CACHE_PATH=logs/search_cache.sqlite
SEARCH_CACHE_TTL_SECONDS=86400
SEARCH_CACHE_MAX_ENTRIES=5000
