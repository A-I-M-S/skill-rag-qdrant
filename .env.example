# Telegram bots
TELEGRAM_INGEST_BOT_TOKEN=
TELEGRAM_QUERY_BOT_TOKEN=

# Qdrant Cloud
QDRANT_URL=https://b21e5b04-433a-41b9-b23d-0416e99a40d9.australia-southeast1-0.gcp.cloud.qdrant.io
QDRANT_API_KEY=
QDRANT_COLLECTION=system_rag

# Embeddings
FASTEMBED_MODEL=intfloat/multilingual-e5-small
EMBEDDING_DIM=384

# Chunking
CHUNK_SIZE=900
CHUNK_OVERLAP=150
TOP_K=6

# Inference
INFERENCE_PROVIDER=openrouter
INFERENCE_TEMPERATURE=0.2

# OpenRouter
OPENROUTER_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_AK=
OPENROUTER_MODEL=z-ai/glm-4.7-flash
OPENROUTER_PROVIDER=cloudflare

# Optional legacy providers
INFERENCE_BASE_URL=
INFERENCE_API_KEY=
INFERENCE_MODEL=

# Optional access control: comma-separated Telegram numeric user IDs. Empty = allow all.
ALLOWED_TELEGRAM_USER_IDS=

# Runtime
LOG_LEVEL=INFO
LOG_FILE=logs/rag-qdrant.log
UPLOAD_DIR=storage/uploads
TEXT_MESSAGE_DIR=storage/text_messages
